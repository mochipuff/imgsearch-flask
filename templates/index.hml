<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ImgScraper | Dark Search</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        gray: {
                            850: '#1f2937',
                            900: '#111827',
                            950: '#030712',
                        }
                    },
                    fontFamily: {
                        mono: ['JetBrains Mono', 'monospace'],
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-out',
                        'slide-up': 'slideUp 0.4s ease-out',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(10px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
        
        * {
            scrollbar-width: thin;
            scrollbar-color: #374151 #111827;
        }
        
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #111827;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #374151;
            border-radius: 3px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #4b5563;
        }
        
        .glass {
            background: rgba(17, 24, 39, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        
        .search-glow:focus-within {
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.5), 0 0 20px rgba(59, 130, 246, 0.3);
        }
        
        /* Responsive Grid Layout - Fixed */
        .responsive-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
            align-items: start;
        }
        
        @media (min-width: 640px) {
            .responsive-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        
        @media (min-width: 768px) {
            .responsive-grid {
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            }
        }
        
        @media (min-width: 1280px) {
            .responsive-grid {
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            }
        }
        
        .image-card {
            position: relative;
            overflow: hidden;
            border-radius: 0.5rem;
            background: #111827;
            border: 1px solid rgba(31, 41, 55, 0.5);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .image-card:hover {
            transform: scale(1.02);
            border-color: #374151;
        }
        
        .image-wrapper {
            position: relative;
            width: 100%;
            overflow: hidden;
        }
        
        .image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: opacity 0.4s ease, transform 0.5s ease;
        }
        
        .image-wrapper img.loaded {
            opacity: 1;
        }
        
        .image-wrapper:hover img.loaded {
            transform: scale(1.05);
        }
        
        .loader {
            width: 48px;
            height: 48px;
            border: 3px solid #1f2937;
            border-radius: 50%;
            display: inline-block;
            position: relative;
            box-sizing: border-box;
            animation: rotation 1s linear infinite;
        }
        
        .loader::after {
            content: '';  
            box-sizing: border-box;
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 3px solid transparent;
            border-bottom-color: #3b82f6;
        }
        
        @keyframes rotation {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        .skeleton {
            background: linear-gradient(90deg, #1f2937 25%, #374151 50%, #1f2937 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
        }
        
        @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Action buttons container */
        .image-actions {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }
        
        .action-btn {
            padding: 0.375rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 9999px;
            transition: all 0.2s;
            backdrop-filter: blur(4px);
        }
        
        .action-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: scale(1.1);
        }
        
        /* Modal improvements */
        .modal-content {
            position: relative;
            max-width: 90vw;
            max-height: 90vh;
        }
        
        .modal-image-container {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .modal-toolbar {
            position: absolute;
            bottom: 1rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 0.75rem;
            padding: 0.75rem 1.5rem;
            background: rgba(17, 24, 39, 0.9);
            backdrop-filter: blur(12px);
            border-radius: 9999px;
            border: 1px solid rgba(55, 65, 81, 0.5);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .modal-content:hover .modal-toolbar {
            opacity: 1;
        }
        
        .modal-btn {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: rgba(59, 130, 246, 0.2);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 0.5rem;
            color: white;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s;
            cursor: pointer;
        }
        
        .modal-btn:hover {
            background: rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
        }
        
        .modal-btn.secondary {
            background: rgba(75, 85, 99, 0.3);
            border-color: rgba(75, 85, 99, 0.5);
        }
        
        .modal-btn.secondary:hover {
            background: rgba(75, 85, 99, 0.5);
        }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans min-h-screen antialiased selection:bg-blue-500/30">

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 glass border-b border-gray-800/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2z"/>
                        </svg>
                    </div>
                    <span class="font-bold text-xl tracking-tight">Img<span class="text-blue-500">Scraper</span></span>
                </div>

                <!-- Search Bar -->
                <form id="searchForm" class="flex-1 max-w-2xl mx-4 sm:mx-8">
                    <div class="relative search-glow rounded-full transition-all duration-300">
                        <input 
                            type="text" 
                            id="searchInput" 
                            placeholder="Search images..." 
                            class="w-full bg-gray-900/80 border border-gray-700 rounded-full py-2.5 pl-5 pr-12 text-sm text-gray-100 placeholder-gray-500 focus:outline-none focus:border-blue-500/50 transition-all"
                            autocomplete="off"
                        >
                        <button 
                            type="submit" 
                            class="absolute right-1.5 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-blue-400 transition-colors"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
                            </svg>
                        </button>
                    </div>
                </form>

                <!-- Stats -->
                <div class="hidden sm:flex items-center gap-4 text-xs text-gray-500 font-mono">
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                        <span id="connectionStatus">Connected</span>
                    </div>
                    <span id="resultCount" class="hidden"></span>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-[1600px] mx-auto">
        
        <!-- Empty State -->
        <div id="emptyState" class="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div class="w-24 h-24 mb-6 rounded-2xl bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center border border-gray-800">
                <svg class="w-12 h-12 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
                </svg>
            </div>
            <h2 class="text-2xl font-semibold text-gray-300 mb-2">Start Searching</h2>
            <p class="text-gray-500 text-sm max-w-md">Enter a keyword above to discover high-quality images from across the web.</p>
            
            <!-- Quick Tags -->
            <div class="flex flex-wrap justify-center gap-2 mt-6">
                <button class="quick-tag px-4 py-2 bg-gray-900 border border-gray-800 rounded-full text-xs text-gray-400 hover:text-white hover:border-gray-600 transition-all" data-query="nature">Nature</button>
                <button class="quick-tag px-4 py-2 bg-gray-900 border border-gray-800 rounded-full text-xs text-gray-400 hover:text-white hover:border-gray-600 transition-all" data-query="architecture">Architecture</button>
                <button class="quick-tag px-4 py-2 bg-gray-900 border border-gray-800 rounded-full text-xs text-gray-400 hover:text-white hover:border-gray-600 transition-all" data-query="minimal">Minimal</button>
                <button class="quick-tag px-4 py-2 bg-gray-900 border border-gray-800 rounded-full text-xs text-gray-400 hover:text-white hover:border-gray-600 transition-all" data-query="technology">Technology</button>
            </div>
        </div>

        <!-- Loading State -->
        <div id="loadingState" class="hidden flex flex-col items-center justify-center py-20">
            <span class="loader mb-4"></span>
            <p class="text-gray-500 text-sm font-mono animate-pulse">Scraping data...</p>
        </div>

        <!-- Image Grid -->
        <div id="imageContainer" class="hidden">
            <div id="imageGrid" class="responsive-grid">
                <!-- Images injected here -->
            </div>
        </div>

        <!-- Error State -->
        <div id="errorState" class="hidden flex flex-col items-center justify-center py-12 text-center">
            <div class="w-16 h-16 mb-4 rounded-full bg-red-500/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-300 mb-1">Search Failed</h3>
            <p id="errorMessage" class="text-gray-500 text-sm max-w-md mb-4">Something went wrong</p>
            <button id="retryBtn" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 rounded-lg text-sm text-white transition-colors">
                Try Again
            </button>
        </div>

        <!-- Load More -->
        <div id="loadMoreContainer" class="hidden flex justify-center mt-8">
            <button id="loadMoreBtn" class="group relative px-6 py-3 bg-gray-900 border border-gray-800 rounded-full text-sm font-medium text-gray-300 hover:text-white hover:border-gray-600 transition-all overflow-hidden">
                <span class="relative z-10 flex items-center gap-2">
                    Load More
                    <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </span>
                <div class="absolute inset-0 bg-gradient-to-r from-blue-600/20 to-purple-600/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </button>
        </div>

        <!-- End State -->
        <div id="endState" class="hidden text-center py-12">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-900/50 border border-gray-800 rounded-full text-xs text-gray-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                All images loaded
            </div>
        </div>
    </main>

    <!-- Image Modal -->
    <div id="imageModal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/95 backdrop-blur-sm" id="modalOverlay"></div>
        <div class="relative h-full flex items-center justify-center p-4">
            <button id="closeModal" class="absolute top-4 right-4 p-2 text-gray-400 hover:text-white transition-colors z-10 bg-black/20 rounded-full backdrop-blur-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
            
            <div class="modal-content">
                <div class="modal-image-container">
                    <img id="modalImage" src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl">
                    
                    <!-- Modal Toolbar with Download -->
                    <div class="modal-toolbar">
                        <button id="downloadBtn" class="modal-btn">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                            </svg>
                            Download
                        </button>
                        <button id="openOriginalBtn" class="modal-btn secondary">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                            Open Original
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-4 right-4 z-50 transform translate-y-20 opacity-0 transition-all duration-300">
        <div class="bg-gray-900 border border-gray-800 rounded-lg px-4 py-3 shadow-xl flex items-center gap-3">
            <div id="toastIcon"></div>
            <span id="toastMessage" class="text-sm text-gray-300"></span>
        </div>
    </div>

    <script>
        // State Management
        const state = {
            query: '',
            offset: 1,
            isLoading: false,
            hasMore: true,
            images: [],
            currentImageUrl: ''
        };

        // DOM Elements
        const elements = {
            searchForm: document.getElementById('searchForm'),
            searchInput: document.getElementById('searchInput'),
            imageGrid: document.getElementById('imageGrid'),
            imageContainer: document.getElementById('imageContainer'),
            emptyState: document.getElementById('emptyState'),
            loadingState: document.getElementById('loadingState'),
            errorState: document.getElementById('errorState'),
            errorMessage: document.getElementById('errorMessage'),
            loadMoreBtn: document.getElementById('loadMoreBtn'),
            loadMoreContainer: document.getElementById('loadMoreContainer'),
            endState: document.getElementById('endState'),
            resultCount: document.getElementById('resultCount'),
            retryBtn: document.getElementById('retryBtn'),
            modal: document.getElementById('imageModal'),
            modalImage: document.getElementById('modalImage'),
            closeModal: document.getElementById('closeModal'),
            modalOverlay: document.getElementById('modalOverlay'),
            connectionStatus: document.getElementById('connectionStatus'),
            toast: document.getElementById('toast'),
            toastMessage: document.getElementById('toastMessage'),
            toastIcon: document.getElementById('toastIcon'),
            downloadBtn: document.getElementById('downloadBtn'),
            openOriginalBtn: document.getElementById('openOriginalBtn')
        };

        // Socket.IO Connection
        const socket = io({
            transports: ['websocket'],
            upgrade: true,
            reconnection: true,
            reconnectionAttempts: 5,
            reconnectionDelay: 1000
        });

        // Socket Event Handlers
        socket.on('connect', () => {
            elements.connectionStatus.textContent = 'Connected';
            elements.connectionStatus.previousElementSibling.classList.remove('bg-red-500', 'bg-yellow-500');
            elements.connectionStatus.previousElementSibling.classList.add('bg-green-500');
        });

        socket.on('disconnect', () => {
            elements.connectionStatus.textContent = 'Disconnected';
            elements.connectionStatus.previousElementSibling.classList.remove('bg-green-500');
            elements.connectionStatus.previousElementSibling.classList.add('bg-red-500');
        });

        socket.on('connect_error', () => {
            elements.connectionStatus.textContent = 'Error';
            elements.connectionStatus.previousElementSibling.classList.remove('bg-green-500');
            elements.connectionStatus.previousElementSibling.classList.add('bg-yellow-500');
        });

        socket.on('search_response', handleSearchResponse);
        socket.on('search_error', handleSearchError);

        // Event Listeners
        elements.searchForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const query = elements.searchInput.value.trim();
            if (!query || state.isLoading) return;
            
            resetSearch();
            state.query = query;
            performSearch();
        });

        elements.loadMoreBtn.addEventListener('click', () => {
            if (!state.isLoading && state.hasMore) {
                performSearch();
            }
        });

        elements.retryBtn.addEventListener('click', () => {
            elements.errorState.classList.add('hidden');
            performSearch();
        });

        // Quick Tags
        document.querySelectorAll('.quick-tag').forEach(btn => {
            btn.addEventListener('click', () => {
                elements.searchInput.value = btn.dataset.query;
                elements.searchForm.dispatchEvent(new Event('submit'));
            });
        });

        // Modal
        elements.closeModal.addEventListener('click', closeModal);
        elements.modalOverlay.addEventListener('click', closeModal);
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });

        // Download button in modal
        elements.downloadBtn.addEventListener('click', () => {
            if (state.currentImageUrl) {
                downloadImage(state.currentImageUrl);
            }
        });

        // Open original button in modal
        elements.openOriginalBtn.addEventListener('click', () => {
            if (state.currentImageUrl) {
                window.open(state.currentImageUrl, '_blank');
            }
        });

        function closeModal() {
            elements.modal.classList.add('hidden');
            document.body.style.overflow = '';
            state.currentImageUrl = '';
        }

        function openModal(src) {
            state.currentImageUrl = src;
            elements.modalImage.src = src;
            elements.modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            // Reset image opacity for loading animation
            elements.modalImage.style.opacity = '0';
            elements.modalImage.onload = () => {
                elements.modalImage.style.transition = 'opacity 0.3s ease';
                elements.modalImage.style.opacity = '1';
            };
        }

        // Download function
        async function downloadImage(url) {
            try {
                showToast('info', 'Downloading...');
                
                // Fetch the image
                const response = await fetch(url);
                const blob = await response.blob();
                
                // Create object URL
                const blobUrl = window.URL.createObjectURL(blob);
                
                // Create temporary link
                const link = document.createElement('a');
                link.href = blobUrl;
                
                // Extract filename from URL or use default
                const filename = url.split('/').pop().split('?')[0] || 'image.jpg';
                link.download = filename;
                
                // Trigger download
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                // Cleanup
                window.URL.revokeObjectURL(blobUrl);
                
                showToast('success', 'Download started');
            } catch (error) {
                console.error('Download failed:', error);
                showToast('error', 'Download failed. Try opening in new tab.');
                
                // Fallback: open in new tab
                setTimeout(() => {
                    window.open(url, '_blank');
                }, 1000);
            }
        }

        // Search Functions
        function resetSearch() {
            state.offset = 1;
            state.hasMore = true;
            state.images = [];
            elements.imageGrid.innerHTML = '';
            elements.imageContainer.classList.add('hidden');
            elements.emptyState.classList.add('hidden');
            elements.errorState.classList.add('hidden');
            elements.endState.classList.add('hidden');
            elements.loadMoreContainer.classList.add('hidden');
            elements.resultCount.classList.add('hidden');
        }

        function performSearch() {
            if (state.isLoading) return;
            
            state.isLoading = true;
            elements.loadingState.classList.remove('hidden');
            elements.loadMoreBtn.classList.add('opacity-50', 'cursor-not-allowed');
            
            socket.emit('request_search', {
                query: state.query,
                offset: state.offset,
                limit: 10
            });
        }

        function handleSearchResponse(data) {
            state.isLoading = false;
            elements.loadingState.classList.add('hidden');
            elements.loadMoreBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            
            if (data.images && data.images.length > 0) {
                state.images.push(...data.images);
                renderImages(data.images);
                
                elements.imageContainer.classList.remove('hidden');
                elements.resultCount.textContent = `${state.images.length} images`;
                elements.resultCount.classList.remove('hidden');
                
                // Update state
                state.hasMore = data.has_more;
                state.offset = data.next_offset || state.offset + 10;
                
                if (state.hasMore) {
                    elements.loadMoreContainer.classList.remove('hidden');
                } else {
                    elements.loadMoreContainer.classList.add('hidden');
                    if (state.images.length >= 10) {
                        elements.endState.classList.remove('hidden');
                    }
                }
                
                showToast('success', `Found ${data.images.length} images`);
            } else {
                if (state.images.length === 0) {
                    showError('No images found for your search');
                } else {
                    elements.endState.classList.remove('hidden');
                }
            }
        }

        function handleSearchError(data) {
            state.isLoading = false;
            elements.loadingState.classList.add('hidden');
            elements.loadMoreBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            
            showError(data.message || 'An error occurred');
            showToast('error', data.message || 'Search failed');
        }

        function renderImages(images) {
            const fragment = document.createDocumentFragment();
            
            images.forEach((img, index) => {
                const card = createImageCard(img, index);
                fragment.appendChild(card);
            });
            
            elements.imageGrid.appendChild(fragment);
        }

        function createImageCard(img, index) {
            const div = document.createElement('div');
            div.className = 'image-card animate-fade-in group cursor-pointer';
            div.style.animationDelay = `${index * 50}ms`;
            
            // Calculate aspect ratio
            const aspectRatio = img.width && img.height ? img.height / img.width : 1;
            const height = aspectRatio !== 1 ? `${aspectRatio * 100}%` : '75%';
            
            div.innerHTML = `
                <div class="image-wrapper" style="padding-bottom: ${height}">
                    <!-- Skeleton loader -->
                    <div class="skeleton absolute inset-0 z-0"></div>
                    
                    <!-- Actual image (hidden until loaded) -->
                    <img 
                        src="${img.thumbnail}" 
                        alt="${img.title || 'Image'}"
                        class="absolute inset-0 w-full h-full object-cover z-10"
                        loading="lazy"
                        data-original="${img.original_url}"
                    >
                    
                    <!-- Hover overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20">
                        <div class="absolute bottom-0 left-0 right-0 p-3">
                            <p class="text-xs text-gray-300 line-clamp-2 font-medium mb-2">${img.title || 'Untitled'}</p>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] text-gray-500 truncate max-w-[50%]">${img.source || ''}</span>
                                <div class="image-actions">
                                    <button class="action-btn download-btn" title="Download" data-url="${img.original_url}">
                                        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                        </svg>
                                    </button>
                                    <button class="action-btn open-original-btn" title="Open original" data-url="${img.original_url}">
                                        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            const imageEl = div.querySelector('img');
            const skeletonEl = div.querySelector('.skeleton');
            
            // Handle image load
            imageEl.addEventListener('load', () => {
                imageEl.classList.add('loaded');
                skeletonEl.style.display = 'none';
            });
            
            // Handle image error
            imageEl.addEventListener('error', () => {
                div.style.display = 'none';
            });
            
            // Click to open modal
            div.addEventListener('click', (e) => {
                if (!e.target.closest('.action-btn')) {
                    openModal(img.original_url);
                }
            });
            
            // Download button
            const downloadBtn = div.querySelector('.download-btn');
            downloadBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                downloadImage(img.original_url);
            });
            
            // Open original button
            const openBtn = div.querySelector('.open-original-btn');
            openBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                window.open(img.original_url, '_blank');
            });
            
            return div;
        }

        function showError(message) {
            elements.errorMessage.textContent = message;
            elements.errorState.classList.remove('hidden');
            elements.imageContainer.classList.add('hidden');
            elements.loadMoreContainer.classList.add('hidden');
        }

        function showToast(type, message) {
            const icons = {
                success: '<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>',
                error: '<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>',
                info: '<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
            };
            
            elements.toastIcon.innerHTML = icons[type] || icons.info;
            elements.toastMessage.textContent = message;
            elements.toast.classList.remove('translate-y-20', 'opacity-0');
            
            setTimeout(() => {
                elements.toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            // Ctrl/Cmd + K to focus search
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                elements.searchInput.focus();
            }
            // / to focus search
            if (e.key === '/' && document.activeElement !== elements.searchInput) {
                e.preventDefault();
                elements.searchInput.focus();
            }
        });

        // Initialize
        console.log('%c ImgScraper ', 'background: #3b82f6; color: white; padding: 4px 8px; border-radius: 4px; font-weight: bold;');
        console.log('%c Dark Mode Initialized ', 'color: #6b7280; font-size: 12px;');
    </script>
</body>
</html>
